UnityRunicTablet: {
	DisplayName: 团结符文石板
	Tooltip:
		'''
		收藏以发挥作用
		融合所有职业符文石板的终极之力
		---万法归一，统御全场

		[c/FFD700:效果汇总:]
		[c/00FF00:战士:] 近战击中回复生命 + 自动挥舞
		[c/00FF00:射手:] 护甲穿透 + 距离暴击加成
		[c/00FF00:法师:] 最大法力值 + 魔法暴击 + 魔力病加速
		[c/00FF00:召唤:] 召唤伤害 + 标记暴击率
		'''
}

