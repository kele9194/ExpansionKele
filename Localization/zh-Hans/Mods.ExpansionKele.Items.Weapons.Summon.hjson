SpaceFunnel: {
	Tooltip:
		'''
		召唤可以发射激光的浮游炮
		激光附加诅咒焰减益
		'''
	DisplayName: 太空浮游炮
}

GoldenWeaverNeedle: {
	Tooltip:
		'''
		可造成挥舞伤害（召唤伤害）
		挥舞时召唤一支金针
		只允许一根金针存在
		金针伤害受玩家是否手持金织之针，最大召唤栏，空余召唤栏影响
		---生命脆弱游丝，谎言纤毫毕现
		---[崩铁]阿格莱雅
		'''
	DisplayName: 金织之针
}

RemoteGatling: {
	DisplayName: 遥控加特林站台
	Tooltip:
		'''
		部署一座自动加特林武器站
		武器站发射特制的铬钢弹
		造成20点盔甲穿透
		'''
}
